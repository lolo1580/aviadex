# Aviadex container example configuration

# Image to run. Use v1.0.0 or latest tags as needed.
AVIADEX_IMAGE=harbor.kellerflix.org/aviadex/prod:v1.0.0

# Host port exposed by Docker Compose.
AVIADEX_HTTP_PORT=8080

# Internal Postgres defaults used by exemple.compose.yml.
POSTGRES_DB=aviadex
POSTGRES_USER=aviadex
POSTGRES_PASSWORD=change-me

# To use an external Postgres, replace this with your external connection string.
DATABASE_URL=postgres://aviadex:change-me@postgres:5432/aviadex
DATABASE_SCHEMA=aviadex

# First admin account. On startup, Aviadex creates the user and repairs role/display metadata without resetting an existing password.
AVIADEX_ADMIN_EMAIL=admin@aviadex.local
AVIADEX_ADMIN_PASSWORD=change-this-password
AVIADEX_ADMIN_DISPLAY_NAME=Aviadex Admin

# Set to true when Aviadex is served over HTTPS.
SECURE_COOKIES=false
SESSION_COOKIE_NAME=aviadex_session
SESSION_TTL_DAYS=14

# Uploaded image files are stored on disk. PostgreSQL stores only references and metadata.
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=10485760
